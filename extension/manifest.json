{
  "manifest_version": 3,
  "name": "PrepOps Save Job",
  "version": "0.1.0",
  "description": "Save job opportunities to local PrepOps.",
  "permissions": ["activeTab", "scripting", "notifications"],
  "host_permissions": ["http://localhost:3000/*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
