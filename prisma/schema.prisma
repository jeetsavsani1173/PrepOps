generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum OpportunityStatus {
  SAVED
  APPLIED
  INTERVIEW
  BETTER_LUCK_NEXT_TIME
}

enum ApplicationDecision {
  APPLY_NOW
  APPLY_AFTER_PREP
  SKIP
}

enum PrepDifficulty {
  LOW
  MEDIUM
  HIGH
}

enum ReferralChannel {
  LINKEDIN
  EMAIL
  OTHER
}

enum ReferralStatus {
  PLANNED
  REQUESTED
  FOLLOWED_UP
  RESPONDED
  REFERRED
  DECLINED
  CLOSED
}

model Opportunity {
  id                      String                @id @default(uuid())
  companyName             String
  roleTitle               String
  source                  String
  jobUrl                  String?
  location                String?
  salary                  String?
  jobDescription          String?
  status                  OpportunityStatus     @default(SAVED)
  retentionDays           Int                   @default(14)
  aiMatchScore            Int?

  scrapedRawText          String?
  scrapedHtml             String?
  employmentType          String?
  workModel               String?
  experienceLevel         String?
  requiredSkills          String?
  preferredSkills         String?
  responsibilities        String?
  qualifications          String?
  applicationDecision     ApplicationDecision?
  prepDifficulty          PrepDifficulty?
  aiRecommendationReason  String?

  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  statusHistory           StatusHistory[]
  interviewNotes          InterviewNote[]
  prepTasks               PrepTask[]
  referralRequests        ReferralRequest[]

  @@index([status])
  @@index([createdAt])
  @@index([jobUrl])
}

model StatusHistory {
  id            String             @id @default(uuid())
  opportunityId String
  fromStatus    OpportunityStatus
  toStatus      OpportunityStatus
  changedAt     DateTime           @default(now())

  opportunity   Opportunity        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([changedAt])
}

model InterviewNote {
  id            String      @id @default(uuid())
  opportunityId String
  roundName     String
  questions     String?
  feedback      String?
  learnings     String?
  followUps     String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
}

model PrepTask {
  id            String      @id @default(uuid())
  opportunityId String
  title         String
  isCompleted   Boolean     @default(false)
  dueDate       DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  opportunity   Opportunity @relation(fields: [opportunityId], references: [id], onDelete: Cascade)

  @@index([opportunityId])
  @@index([isCompleted])
}

model ReferralRequest {
  id              String             @id @default(uuid())
  opportunityId   String
  contactName     String
  contactTitle    String?
  contactCompany  String?
  contactUrl      String?
  contactEmail    String?
  channel         ReferralChannel
  status          ReferralStatus     @default(PLANNED)
  initialMessage  String?
  lastMessage     String?
  nextFollowUpAt  DateTime?
  notes           String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  opportunity     Opportunity        @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  followUps       ReferralFollowUp[]

  @@index([opportunityId])
  @@index([status])
  @@index([nextFollowUpAt])
}

model ReferralFollowUp {
  id                String          @id @default(uuid())
  referralRequestId String
  message           String
  sentAt            DateTime        @default(now())
  nextFollowUpAt    DateTime?
  createdAt         DateTime        @default(now())

  referralRequest   ReferralRequest @relation(fields: [referralRequestId], references: [id], onDelete: Cascade)

  @@index([referralRequestId])
  @@index([sentAt])
}

model ResumeSnapshot {
  id                  String   @id @default(uuid())
  versionName         String
  filePath            String
  extractedSkillsText String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
